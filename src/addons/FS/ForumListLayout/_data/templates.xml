<?xml version="1.0" encoding="utf-8"?>
<templates>
  <template type="public" title="fs_fll_node_sort" version_id="1000500" version_string="1.0.5"><![CDATA[<xf:title>{{ phrase('sort_nodes') }}</xf:title>

<xf:macro template="public:nestable_macros" name="setup" />

<xf:css>
.nodeIcon {
  font-family: 'Font Awesome 5 Pro';
  font-size: inherit;
  font-style: normal;
  font-weight: 400;
  text-rendering: auto;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  color: #505050;
}
.nodeIcon--Category:before {
  content: "\f0c9";
  width: 1.28571429em;
  display: inline-block;
  text-align: center;
}

</xf:css>

<xf:form action="{{ link('forums/sort') }}" class="block" ajax="true">
	<div class="block-container">
		<div class="block-body">
			<div class="nestable-container" data-xf-init="nestable">
				<xf:macro name="node_list" arg-children="{$nodeTree}" />
				<xf:hiddenval name="nodes" value="" />
			</div>
		</div>
		<xf:submitrow icon="save" rowtype="simple" />
	</div>
</xf:form>

<xf:macro name="node_list" arg-children="!">
	<ol class="nestable-list">
		<xf:foreach loop="$children" key="$id" value="$child">
			<xf:macro name="node_list_entry" arg-node="{$child}" arg-children="{$child.children}" />
		</xf:foreach>
	</ol>
</xf:macro>

<xf:macro name="node_list_entry" arg-node="!" arg-children="!">
	<li class="nestable-item" data-id="{$node.id}">
		<div class="nestable-handle" aria-label="{{ phrase('drag_handle')|for_attr }}"><xf:macro name="node_icon" arg-node="{$node.record}" /></div>
		<div class="nestable-content">
			<strong>{$node.record.title}</strong>
			<span class="nestable-label nestable-label--smallest" dir="auto">
				{$node.record.NodeType.title}
				<xf:if is="
					$node.record.node_type_id == 'Forum'
					AND $node.record.Data.TypeHandler
					AND $node.record.Data.forum_type_id != 'discussion'
				">
					({{ $node.record.Data.TypeHandler.getTypeTitle() }})
				</xf:if>
			</span>
		</div>
		<xf:if is="$node.children is not empty">
			<xf:macro name="node_list" arg-children="{$node.children}" />
		</xf:if>
	</li>
</xf:macro>


<xf:macro name="node_icon" arg-node="!">
	<xf:if is="$node.node_type_id == 'Forum' AND $node.Data.TypeHandler">
		<xf:set var="$typeIcon" value="{{ $node.Data.TypeHandler.getTypeIconClass() }}" />
		<xf:if is="$typeIcon">
			
		<xf:else />
			<i class="fa fa-bars" aria-hidden="true"></i>
			
		</xf:if>
	<xf:else />
		<i class="fa fa-bars" aria-hidden="true"></i>
		
	</xf:if>
</xf:macro>]]></template>
  <template type="public" title="fs_forum_list_layout.less" version_id="1000200" version_string="1.0.2"><![CDATA[.fs-grid-list {
 	display: grid !important;
    grid-template-columns: repeat(3, 1fr);
}

@media (max-width:650px)
{
	.fs-grid-list 
	{
		grid-template-columns: repeat(2, 1fr);
	}
}

[data-template="forum_list"]
{
	.node-stats,
	.node-extra,
	.node-statsMeta
	{
		display:none !important;
	}
}]]></template>
</templates>
